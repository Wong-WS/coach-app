rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(coachId) {
      return request.auth != null && request.auth.uid == coachId;
    }

    function isValidDay(day) {
      return day in ['monday', 'tuesday', 'wednesday', 'thursday', 'friday', 'saturday', 'sunday'];
    }

    function isValidPreferredTime(time) {
      return time in ['morning', 'afternoon', 'evening', 'any'];
    }

    // Coach slugs - authenticated create (own uid only), no public read (served via API)
    match /coachSlugs/{slug} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.coachId == request.auth.uid;
      allow update, delete: if false;
    }

    // Student portal token lookup - authenticated create, no update/delete
    match /studentTokens/{token} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.coachId == request.auth.uid;
      allow update, delete: if false;
    }

    // Coach profiles - owner only (public page served via API route using admin SDK)
    match /coaches/{coachId} {
      allow read, write: if isOwner(coachId);

      // Working hours - owner only (served via API route)
      match /workingHours/{day} {
        allow read, write: if isOwner(coachId);
      }

      // Locations - owner only (served via API route)
      match /locations/{locationId} {
        allow read, write: if isOwner(coachId);
      }

      // Bookings - owner only (availability served via API route using admin SDK)
      match /bookings/{bookingId} {
        allow read, write: if isOwner(coachId);
      }

      // Students - owner only
      match /students/{studentId} {
        allow read, write: if isOwner(coachId);
      }

      // Lesson logs - owner only
      match /lessonLogs/{logId} {
        allow read, write: if isOwner(coachId);
      }

      // Class exceptions (cancel/reschedule) - owner only
      match /classExceptions/{exceptionId} {
        allow read, write: if isOwner(coachId);
      }

      // Payments - owner only
      match /payments/{paymentId} {
        allow read, write: if isOwner(coachId);
      }

      // Waitlist - owner read/update/delete, public create with validation
      match /waitlist/{waitlistId} {
        allow read: if isOwner(coachId);
        allow create: if
          request.resource.data.keys().hasOnly(['locationId', 'locationName', 'dayOfWeek', 'preferredTime', 'clientName', 'clientPhone', 'notes', 'status', 'createdAt'])
          && request.resource.data.clientName is string
          && request.resource.data.clientName.size() >= 1
          && request.resource.data.clientName.size() <= 100
          && request.resource.data.clientPhone is string
          && request.resource.data.clientPhone.size() >= 1
          && request.resource.data.clientPhone.size() <= 30
          && request.resource.data.locationId is string
          && request.resource.data.locationId.size() > 0
          && request.resource.data.locationName is string
          && isValidDay(request.resource.data.dayOfWeek)
          && isValidPreferredTime(request.resource.data.preferredTime)
          && request.resource.data.status == 'waiting'
          && (!('notes' in request.resource.data) || (request.resource.data.notes is string && request.resource.data.notes.size() <= 500));
        allow update, delete: if isOwner(coachId);
      }
    }
  }
}
